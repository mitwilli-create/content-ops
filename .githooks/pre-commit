#!/bin/sh
# content-ops pre-commit gate. Enabled via: git config core.hooksPath .githooks
#
# Order matters:
#   1. voice --self-test  the gates still FIRE on known-bad input. A matcher broken by an
#                         edit reports every file clean, so this runs first and always.
#   2. voice --staged     the files in THIS commit pass. Scoped to staged content read from
#                         the index, not a full-repo sweep: a hook that fails on dirt you
#                         did not touch gets bypassed, and a bypassed gate enforces nothing.
#   3. trufflehog         delegated, unchanged, to the pre-existing secret-scan hook.
#
# Step 3 exists because setting core.hooksPath makes git ignore .git/hooks entirely, and
# .git/hooks/pre-commit is a symlink to ~/.config/git/hooks/trufflehog-pre-commit. Without
# this delegation, turning on the voice gate would silently turn OFF the secret scan.
# It is invoked rather than reimplemented so there is exactly one copy of that logic and
# this file inherits any future change to it.
#
# Escape hatch is git's own --no-verify, deliberately: one obvious, visible, per-commit
# action rather than an env var that can be exported once in a shell rc and forgotten.
#
# TWO OPEN ISSUES with the delegated secret scan, both observed 2026-07-20, neither fixed
# here because changing secret-scanning behavior is Mitchell's call, not this gate's:
#
#   a) It appears not to cover staged content. The hook runs `trufflehog git ...
#      --since-commit HEAD`, which scans COMMITS; at pre-commit time the staged blobs are
#      not a commit yet. Measured: a file containing a well-formed AWS key pair, staged but
#      uncommitted, produced exit 0 (no finding) and the commit was allowed through.
#
#   b) Empty-commit hazard in worktrees. Three subagents in git worktrees produced commits
#      that reported success and contained ZERO files, losing their edits. In one agent
#      worktree this reproduced reliably and isolated to this hook: with the hook active,
#      0 files committed; with --no-verify, 1 file; with trufflehog absent from PATH, 1
#      file. It did NOT reproduce in the main tree, nor in a freshly created worktree at
#      current HEAD, so the triggering condition is not established and `env -u
#      GIT_INDEX_FILE` was NOT confirmed as a cure. Treat worktree commits as unverified:
#      check `git show --name-only` before trusting one.
set -e

node scripts/voice-gates.mjs --self-test >/dev/null || {
  echo "voice gates: SELF-TEST FAILED. The gates are not enforcing what they claim."
  node scripts/voice-gates.mjs --self-test
  exit 1
}

node scripts/voice-gates.mjs --staged

# --- delegated secret scan ---------------------------------------------------
UPSTREAM_SECRET_HOOK="$HOME/.config/git/hooks/trufflehog-pre-commit"
if [ -x "$UPSTREAM_SECRET_HOOK" ]; then
  "$UPSTREAM_SECRET_HOOK"
fi
