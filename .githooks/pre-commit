#!/bin/sh
# content-ops pre-commit gate. Enabled via: git config core.hooksPath .githooks
#
# Order matters:
#   1. voice --self-test  the gates still FIRE on known-bad input. A matcher broken by an
#                         edit reports every file clean, so this runs first and always.
#   2. voice --staged     the files in THIS commit pass. Scoped to staged content read from
#                         the index, not a full-repo sweep: a hook that fails on dirt you
#                         did not touch gets bypassed, and a bypassed gate enforces nothing.
#   3. trufflehog         delegated, unchanged, to the pre-existing secret-scan hook.
#
# Step 3 exists because setting core.hooksPath makes git ignore .git/hooks entirely, and
# .git/hooks/pre-commit is a symlink to ~/.config/git/hooks/trufflehog-pre-commit. Without
# this delegation, turning on the voice gate would silently turn OFF the secret scan.
# It is invoked rather than reimplemented so there is exactly one copy of that logic and
# this file inherits any future change to it.
#
# Escape hatch is git's own --no-verify, deliberately: one obvious, visible, per-commit
# action rather than an env var that can be exported once in a shell rc and forgotten.
#
# The two issues previously recorded here as OPEN were root-caused and FIXED upstream on
# 2026-07-20, in ~/.config/git/hooks/trufflehog-pre-commit. Both had one cause:
#
#   git exports GIT_INDEX_FILE (plus GIT_DIR / GIT_WORK_TREE in worktrees) into every
#   hook's environment. The old secret hook ran `trufflehog git "file://$root"`, and
#   trufflehog shells out to git internally while cloning the repo to a temp dir. Those
#   child git processes inherited GIT_INDEX_FILE and wrote into the REAL repo index. The
#   index silently reverted to HEAD, the hook still exited 0, and git printed a normal
#   success line while committing a tree that did not match what was staged.
#
#   a) Staged content was not scanned. FIXED. `--since-commit HEAD` scans COMMITS, and at
#      pre-commit time the staged blobs are not a commit yet. The hook now scans
#      `git diff --cached` over stdin, so it sees exactly what is being committed.
#
#   b) Empty commits in worktrees. FIXED, and it was the same bug, not a separate one. The
#      earlier note said `env -u GIT_INDEX_FILE` was NOT confirmed as a cure; that has
#      since been confirmed. It reproduces deterministically once you set GIT_INDEX_FILE
#      explicitly, which is why it looked worktree-specific: worktrees make git export a
#      full set of repo pointers, so the leak lands more often there than in the main tree.
#      The fix applies both defenses, scanning stdin AND unsetting the pointers.
#
# Verify with `sh ~/.config/git/hooks/trufflehog-pre-commit --self-test`, which asserts
# index integrity, commit content, that a staged secret still blocks, and that an
# untracked secret does not. Run it after touching that hook.
#
# Audit note: two commits were lost to this before the fix (5acf249, 4f40dec, both on agent
# worktree branches, zero files each). That work was redone in 155e09b and 4805f59. To scan
# for others, flag any commit whose tree equals its parent's tree, excluding git stash
# entries, whose trees legitimately match.
set -e

node scripts/voice-gates.mjs --self-test >/dev/null || {
  echo "voice gates: SELF-TEST FAILED. The gates are not enforcing what they claim."
  node scripts/voice-gates.mjs --self-test
  exit 1
}

node scripts/voice-gates.mjs --staged

# --- delegated secret scan ---------------------------------------------------
UPSTREAM_SECRET_HOOK="$HOME/.config/git/hooks/trufflehog-pre-commit"
if [ -x "$UPSTREAM_SECRET_HOOK" ]; then
  "$UPSTREAM_SECRET_HOOK"
fi
